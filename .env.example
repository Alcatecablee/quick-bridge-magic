# Supabase (signaling channels - no data is stored)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Vite-exposed copies (must be VITE_ prefixed to reach the browser)
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"

# Replit dev proxy domain - used so QR pair links are scannable from other devices
# Leave blank in production / when deploying to a real domain
VITE_DEV_DOMAIN=""

# Optional: custom TURN server overrides (defaults to Open Relay free TURN)
# VITE_TURN_URLS="turn:turn.example.com:3478"
# VITE_TURN_USERNAME=""
# VITE_TURN_CREDENTIAL=""
